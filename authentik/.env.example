# =========================================================
# Authentik Environment Configuration
# Copy this file to .env and replace the placeholder values.
# =========================================================

# PostgreSQL
PG_DB=authentik
PG_USER=authentik
PG_PASS=change_me

# Authentik
AUTHENTIK_SECRET_KEY=replace_with_a_long_random_secret

# Container Image
AUTHENTIK_IMAGE=ghcr.io/goauthentik/server
AUTHENTIK_TAG=2026.5.3

# Ports
COMPOSE_PORT_HTTP=9000
COMPOSE_PORT_HTTPS=9444
