# =========================================================
# RevChatham Homelab
# Global .gitignore
# =========================================================

# =========================================================
# Environment Files & Secrets
# =========================================================

.env
.env.*
!.env.example

# Certificates & Keys
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx

# SSH Keys
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# =========================================================
# Logs
# =========================================================

*.log
logs/

# =========================================================
# Operating System Files
# =========================================================

# Linux
*~

# macOS
.DS_Store

# Windows
Thumbs.db
desktop.ini

# =========================================================
# IDE / Editor Files
# =========================================================

.vscode/
.idea/

# =========================================================
# Python
# =========================================================

__pycache__/
*.pyc

# =========================================================
# Homepage
# =========================================================

docker/homepage/config/logs/

# =========================================================
# Pi-hole
# =========================================================

docker/pihole/etc-pihole/
docker/pihole/etc-dnsmasq.d/

# =========================================================
# Authentik
# =========================================================

docker/authentik/data/
docker/authentik/certs/

# Keep custom templates only if they contain your own work.
# If they remain empty or stock templates, they can stay in Git.
# docker/authentik/custom-templates/

