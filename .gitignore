# =========================================================
# RevChatham Homelab
# Global .gitignore
# =========================================================

# =========================================================
# Environment Files & Secrets
# =========================================================

.env
.env.*
!.env.example

# =========================================================
# Certificates & Keys
# =========================================================

*.pem
*.key
*.crt
*.csr
*.p12
*.pfx

# =========================================================
# SSH Keys
# =========================================================

id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# =========================================================
# Logs
# =========================================================

*.log
logs/

# =========================================================
# Temporary and Backup Files
# =========================================================

*.bak
*.tmp

# =========================================================
# Operating System Files
# =========================================================

# Linux
*~

# macOS
.DS_Store

# Windows
Thumbs.db
desktop.ini

# =========================================================
# IDE / Editor Files
# =========================================================

.vscode/
.idea/

# =========================================================
# Python
# =========================================================

__pycache__/
*.pyc

# =========================================================
# Recovery and Backup Artifacts
# =========================================================

automation/recovery/output/

Recovery_Points/
*.tar.gz
*.vma
*.vma.zst

# Recovery Automation Example Recovery Point
!automation/recovery/output.example/
!automation/recovery/output.example/**
